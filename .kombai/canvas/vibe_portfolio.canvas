        "config": {}
      },
      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700;800&family=Inter:wght@400;500;600&display=swap');\n\n  :root {\n    --aurora-1: #1e1b4b;\n    --aurora-2: #0891b2;\n    --bg-main: #020617;\n  }\n\n  body {\n    margin: 0;\n    padding: 0;\n    background-color: var(--bg-main);\n    color: white;\n    font-family: 'Inter', sans-serif;\n    overflow-x: hidden;\n  }\n\n  h1, h2, h3, h4 {\n    font-family: 'Plus Jakarta Sans', sans-serif;\n  }\n\n  .aurora-bg {\n    position: fixed;\n    inset: 0;\n    z-index: -1;\n    overflow: hidden;\n  }\n\n  .blob {\n    position: absolute;\n    border-radius: 50%;\n    filter: blur(80px);\n    opacity: 0.4;\n    animation: move 20s infinite alternate ease-in-out;\n  }\n\n  .blob-1 {\n    width: 600px;\n    height: 600px;\n    background: var(--aurora-1);\n    top: -100px;\n    left: -100px;\n  }\n\n  .blob-2 {\n    width: 500px;\n    height: 500px;\n    background: var(--aurora-2);\n    bottom: -100px;\n    right: -100px;\n    animation-delay: -5s;\n  }\n\n  @keyframes move {\n    from { transform: translate(0, 0) scale(1); }\n    to { transform: translate(100px, 100px) scale(1.1); }\n  }\n\n  .glass-card {\n    background: rgba(255, 255, 255, 0.03);\n    backdrop-filter: blur(40px);\n    border: 1px solid rgba(255, 255, 255, 0.08);\n    box-shadow: 0 0 40px rgba(0, 0, 0, 0.5);\n  }\n\n  .step-dot {\n    width: 12px;\n    height: 12px;\n    border-radius: 50%;\n    background: rgba(255, 255, 255, 0.2);\n    transition: all 0.3s ease;\n    position: relative;\n    z-index: 10;\n  }\n\n  .step-dot.active {\n    background: #0891b2;\n    box-shadow: 0 0 15px #0891b2;\n  }\n\n  .step-line {\n    position: absolute;\n    top: 50%;\n    left: 0;\n    right: 0;\n    height: 2px;\n    background: rgba(255, 255, 255, 0.1);\n    transform: translateY(-50%);\n    z-index: 5;\n  }\n\n  .step-line-progress {\n    position: absolute;\n    top: 0;\n    left: 0;\n    height: 100%;\n    background: #0891b2;\n    transition: width 0.5s ease;\n  }\n\n  .option-card {\n    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);\n  }\n\n  .option-card:hover {\n    transform: translateY(-4px);\n    background: rgba(255, 255, 255, 0.06);\n    border-color: rgba(255, 255, 255, 0.2);\n  }\n\n  .option-card.selected {\n    background: rgba(8, 145, 178, 0.1);\n    border-color: #0891b2;\n    box-shadow: 0 0 20px rgba(8, 145, 178, 0.15);\n  }\n\n  input, textarea {\n    background: rgba(255, 255, 255, 0.05);\n    border: 1px solid rgba(255, 255, 255, 0.1);\n    color: white;\n    outline: none;\n    transition: all 0.3s ease;\n  }\n\n  input:focus, textarea:focus {\n    border-color: #0891b2;\n    background: rgba(255, 255, 255, 0.08);\n  }\n\n  .btn-primary {\n    background: linear-gradient(135deg, #0891b2, #1e1b4b);\n    transition: all 0.3s ease;\n  }\n\n  .btn-primary:hover {\n    filter: brightness(1.2);\n    transform: translateY(-2px);\n    box-shadow: 0 10px 20px rgba(8, 145, 178, 0.2);\n  }\n\n  .custom-checkbox {\n    width: 20px;\n    height: 20px;\n    border: 2px solid rgba(255, 255, 255, 0.2);\n    border-radius: 6px;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    transition: all 0.2s ease;\n  }\n\n  .checkbox-container:hover .custom-checkbox {\n    border-color: #0891b2;\n  }\n\n  input:checked + .custom-checkbox {\n    background: #0891b2;\n    border-color: #0891b2;\n  }\n\n  .fade-in {\n    animation: fadeIn 0.5s ease-out forwards;\n  }\n\n  @keyframes fadeIn {\n    from { opacity: 0; transform: translateY(10px); }\n    to { opacity: 1; transform: translateY(0); }\n  }\n</style>\n\n<div class=\"aurora-bg\" data-kid=\"1\">\n  <div class=\"blob blob-1\" data-kid=\"2\"></div>\n  <div class=\"blob blob-2\" data-kid=\"3\"></div>\n</div>\n\n<main class=\"min-h-screen flex items-center justify-center p-8\" data-kid=\"4\">\n  <div class=\"w-full max-w-4xl glass-card rounded-[40px] p-10 md:p-16 relative overflow-hidden\" data-kid=\"5\">\n    \n    <div class=\"flex flex-col items-center mb-12\" data-kid=\"6\">\n      <div class=\"inline-flex items-center px-4 py-1 rounded-full bg-cyan-900/30 border border-cyan-500/30 text-cyan-400 text-xs font-semibold tracking-widest uppercase mb-4\" data-kid=\"7\">\n        Premium Calculator v3.1\n      </div>\n      <h1 class=\"text-4xl md:text-5xl font-extrabold text-center mb-10 tracking-tight leading-tight\" data-kid=\"8\">\n        Расчет стоимости <span class=\"text-cyan-400\" data-kid=\"9\">проекта</span>\n      </h1>\n      \n      <div class=\"w-full max-w-md relative px-4\" data-kid=\"10\">\n        <div class=\"step-line\" data-kid=\"11\">\n          <div id=\"progress-bar\" class=\"step-line-progress\" style=\"width: 0%\" data-kid=\"12\"></div>\n        </div>\n        <div class=\"flex justify-between\" data-kid=\"13\">\n          <div class=\"step-dot active\" data-step=\"1\" data-kid=\"14\"></div>\n          <div class=\"step-dot\" data-step=\"2\" data-kid=\"15\"></div>\n          <div class=\"step-dot\" data-step=\"3\" data-kid=\"16\"></div>\n          <div class=\"step-dot\" data-step=\"4\" data-kid=\"17\"></div>\n          <div class=\"step-dot\" data-step=\"5\" data-kid=\"18\"></div>\n        </div>\n      </div>\n    </div>\n\n    \n    <div id=\"step-1\" class=\"step-content fade-in\" data-kid=\"19\">\n      <p class=\"text-center text-slate-400 mb-8\" data-kid=\"20\">Выберите тип вашего будущего продукта</p>\n      <div class=\"grid grid-cols-2 md:grid-cols-3 gap-4\" data-kid=\"21\">\n        <button class=\"option-card p-6 rounded-3xl border border-white/5 flex flex-col items-center text-center group\" onclick=\"selectType('landing', this)\" data-kid=\"22\">\n          <div class=\"w-12 h-12 rounded-2xl bg-white/5 flex items-center justify-center mb-4 group-hover:bg-cyan-500/20 transition-colors\" data-kid=\"23\">\n            <span class=\"text-2xl\" data-kid=\"24\">🌐</span>\n          </div>\n          <span class=\"font-semibold text-sm\" data-kid=\"25\">Лендинг / Визитка</span>\n        </button>\n        <button class=\"option-card p-6 rounded-3xl border border-white/5 flex flex-col items-center text-center group\" onclick=\"selectType('corporate', this)\" data-kid=\"26\">\n          <div class=\"w-12 h-12 rounded-2xl bg-white/5 flex items-center justify-center mb-4 group-hover:bg-cyan-500/20 transition-colors\" data-kid=\"27\">\n            <span class=\"text-2xl\" data-kid=\"28\">🏢</span>\n          </div>\n          <span class=\"font-semibold text-sm\" data-kid=\"29\">Корпоративный сайт</span>\n        </button>\n        <button class=\"option-card p-6 rounded-3xl border border-white/5 flex flex-col items-center text-center group\" onclick=\"selectType('ecommerce', this)\" data-kid=\"30\">\n          <div class=\"w-12 h-12 rounded-2xl bg-white/5 flex items-center justify-center mb-4 group-hover:bg-cyan-500/20 transition-colors\" data-kid=\"31\">\n            <span class=\"text-2xl\" data-kid=\"32\">🛒</span>\n          </div>\n          <span class=\"font-semibold text-sm\" data-kid=\"33\">Интернет-магазин</span>\n        </button>\n        <button class=\"option-card p-6 rounded-3xl border border-white/5 flex flex-col items-center text-center group\" onclick=\"selectType('webapp', this)\" data-kid=\"34\">\n          <div class=\"w-12 h-12 rounded-2xl bg-white/5 flex items-center justify-center mb-4 group-hover:bg-cyan-500/20 transition-colors\" data-kid=\"35\">\n            <span class=\"text-2xl\" data-kid=\"36\">💻</span>\n          </div>\n          <span class=\"font-semibold text-sm\" data-kid=\"37\">Веб-приложение (SaaS)</span>\n        </button>\n        <button class=\"option-card p-6 rounded-3xl border border-white/5 flex flex-col items-center text-center group\" onclick=\"selectType('mobile', this)\" data-kid=\"38\">\n          <div class=\"w-12 h-12 rounded-2xl bg-white/5 flex items-center justify-center mb-4 group-hover:bg-cyan-500/20 transition-colors\" data-kid=\"39\">\n            <span class=\"text-2xl\" data-kid=\"40\">📱</span>\n          </div>\n          <span class=\"font-semibold text-sm\" data-kid=\"41\">Мобильное приложение</span>\n        </button>\n        <button class=\"option-card p-6 rounded-3xl border border-white/5 flex flex-col items-center text-center group\" onclick=\"selectType('telegram', this)\" data-kid=\"42\">\n          <div class=\"w-12 h-12 rounded-2xl bg-white/5 flex items-center justify-center mb-4 group-hover:bg-cyan-500/20 transition-colors\" data-kid=\"43\">\n            <span class=\"text-2xl\" data-kid=\"44\">🤖</span>\n          </div>\n          <span class=\"font-semibold text-sm\" data-kid=\"45\">Telegram бот</span>\n        </button>\n        <button class=\"option-card p-6 rounded-3xl border border-white/5 flex flex-col items-center text-center group\" onclick=\"selectType('crm', this)\" data-kid=\"46\">\n          <div class=\"w-12 h-12 rounded-2xl bg-white/5 flex items-center justify-center mb-4 group-hover:bg-cyan-500/20 transition-colors\" data-kid=\"47\">\n            <span class=\"text-2xl\" data-kid=\"48\">📊</span>\n          </div>\n          <span class=\"font-semibold text-sm\" data-kid=\"49\">CRM / Админ-панель</span>\n        </button>\n        <button class=\"option-card p-6 rounded-3xl border border-white/5 flex flex-col items-center text-center group\" onclick=\"selectType('api', this)\" data-kid=\"50\">\n          <div class=\"w-12 h-12 rounded-2xl bg-white/5 flex items-center justify-center mb-4 group-hover:bg-cyan-500/20 transition-colors\" data-kid=\"51\">\n            <span class=\"text-2xl\" data-kid=\"52\">⚙️</span>\n          </div>\n          <span class=\"font-semibold text-sm\" data-kid=\"53\">API / Backend</span>\n        </button>\n        <button class=\"option-card p-6 rounded-3xl border border-white/5 flex flex-col items-center text-center group\" onclick=\"selectType('custom', this)\" data-kid=\"54\">\n          <div class=\"w-12 h-12 rounded-2xl bg-white/5 flex items-center justify-center mb-4 group-hover:bg-cyan-500/20 transition-colors\" data-kid=\"55\">\n            <span class=\"text-2xl\" data-kid=\"56\">✨</span>\n          </div>\n          <span class=\"font-semibold text-sm\" data-kid=\"57\">Своё / Другое</span>\n        </button>\n      </div>\n    </div>\n\n    \n    <div id=\"step-2\" class=\"step-content hidden fade-in\" data-kid=\"58\">\n      <p class=\"text-center text-slate-400 mb-8\" data-kid=\"59\">Определите уровень сложности реализации</p>\n      <div class=\"space-y-4\" data-kid=\"60\">\n        <button class=\"option-card w-full p-6 rounded-3xl border border-white/5 flex items-center gap-6 group\" onclick=\"selectComplexity('simple', this)\" data-kid=\"61\">\n          <div class=\"w-14 h-14 rounded-full bg-cyan-500/10 flex items-center justify-center shrink-0\" data-kid=\"62\">\n            <div class=\"w-6 h-6 rounded-full bg-cyan-500/30\" data-kid=\"63\"></div>\n          </div>\n          <div class=\"text-left\" data-kid=\"64\">\n            <h3 class=\"font-bold text-lg\" data-kid=\"65\">Простой</h3>\n            <p id=\"complex-desc-simple\" class=\"text-sm text-slate-400 mt-1\" data-kid=\"66\">Минимальный функционал, стандартный дизайн</p>\n          </div>\n        </button>\n        <button class=\"option-card w-full p-6 rounded-3xl border border-white/5 flex items-center gap-6 group\" onclick=\"selectComplexity('medium', this)\" data-kid=\"67\">\n          <div class=\"w-14 h-14 rounded-full bg-cyan-500/10 flex items-center justify-center shrink-0\" data-kid=\"68\">\n            <div class=\"flex gap-1\" data-kid=\"69\">\n              <div class=\"w-4 h-4 rounded-full bg-cyan-500/30\" data-kid=\"70\"></div>\n              <div class=\"w-4 h-4 rounded-full bg-cyan-500/50\" data-kid=\"71\"></div>\n            </div>\n          </div>\n          <div class=\"text-left\" data-kid=\"72\">\n            <h3 class=\"font-bold text-lg\" data-kid=\"73\">Средний</h3>\n            <p id=\"complex-desc-medium\" class=\"text-sm text-slate-400 mt-1\" data-kid=\"74\">Оптимальный набор функций, индивидуальные решения</p>\n          </div>\n        </button>\n        <button class=\"option-card w-full p-6 rounded-3xl border border-white/5 flex items-center gap-6 group\" onclick=\"selectComplexity('complex', this)\" data-kid=\"75\">\n          <div class=\"w-14 h-14 rounded-full bg-cyan-500/10 flex items-center justify-center shrink-0\" data-kid=\"76\">\n            <div class=\"flex gap-1\" data-kid=\"77\">\n              <div class=\"w-3 h-3 rounded-full bg-cyan-500/30\" data-kid=\"78\"></div>\n              <div class=\"w-3 h-3 rounded-full bg-cyan-500/50\" data-kid=\"79\"></div>\n              <div class=\"w-3 h-3 rounded-full bg-cyan-500\" data-kid=\"80\"></div>\n            </div>\n          </div>\n          <div class=\"text-left\" data-kid=\"81\">\n            <h3 class=\"font-bold text-lg\" data-kid=\"82\">Продвинутый</h3>\n            <p id=\"complex-desc-complex\" class=\"text-sm text-slate-400 mt-1\" data-kid=\"83\">Сложные интеграции, уникальные анимации, высокая нагрузка</p>\n          </div>\n        </button>\n      </div>\n    </div>\n\n    \n    <div id=\"step-3\" class=\"step-content hidden fade-in\" data-kid=\"84\">\n      <div class=\"space-y-8\" data-kid=\"85\">\n        <div data-kid=\"86\">\n          <label class=\"block text-sm font-semibold text-slate-400 mb-3 uppercase tracking-wider\" data-kid=\"87\">Описание проекта</label>\n          <textarea id=\"description\" class=\"w-full rounded-2xl p-4 min-h-[120px] focus:ring-2 focus:ring-cyan-500/50\" placeholder=\"Расскажите подробнее о вашей идее...\" data-kid=\"88\"></textarea>\n        </div>\n        \n        <div class=\"grid md:grid-cols-2 gap-8\" data-kid=\"89\">\n          <div data-kid=\"90\">\n            <label class=\"block text-sm font-semibold text-slate-400 mb-3 uppercase tracking-wider\" data-kid=\"91\">Техническое задание</label>\n            <div class=\"border-2 border-dashed border-white/10 rounded-3xl p-8 flex flex-col items-center justify-center bg-white/2 hover:bg-white/5 hover:border-cyan-500/30 transition-all cursor-pointer group\" data-kid=\"92\">\n              <div class=\"w-10 h-10 rounded-full bg-white/5 flex items-center justify-center mb-3 group-hover:bg-cyan-500/20\" data-kid=\"93\">\n                <span class=\"text-lg\" data-kid=\"94\">📎</span>\n              </div>\n              <p class=\"text-sm text-slate-400\" data-kid=\"95\">Перетащите файл или выберите</p>\n            </div>\n          </div>\n          <div data-kid=\"96\">\n            <label class=\"block text-sm font-semibold text-slate-400 mb-3 uppercase tracking-wider\" data-kid=\"97\">Функционал</label>\n            <div class=\"flex flex-wrap gap-2\" data-kid=\"98\">\n              <button class=\"px-4 py-2 rounded-xl bg-white/5 border border-white/10 text-xs hover:bg-cyan-500/20 hover:border-cyan-500/40 transition-all chip\" onclick=\"toggleFeature(this)\" data-kid=\"99\">Авторизация</button>\n              <button class=\"px-4 py-2 rounded-xl bg-white/5 border border-white/10 text-xs hover:bg-cyan-500/20 hover:border-cyan-500/40 transition-all chip\" onclick=\"toggleFeature(this)\" data-kid=\"100\">Оплата онлайн</button>\n              <button class=\"px-4 py-2 rounded-xl bg-white/5 border border-white/10 text-xs hover:bg-cyan-500/20 hover:border-cyan-500/40 transition-all chip\" onclick=\"toggleFeature(this)\" data-kid=\"101\">Интеграция CRM</button>\n              <button class=\"px-4 py-2 rounded-xl bg-white/5 border border-white/10 text-xs hover:bg-cyan-500/20 hover:border-cyan-500/40 transition-all chip\" onclick=\"toggleFeature(this)\" data-kid=\"102\">Админ-панель</button>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n\n    \n    <div id=\"step-4\" class=\"step-content hidden fade-in\" data-kid=\"103\">\n      <p class=\"text-center text-slate-400 mb-8\" data-kid=\"104\">Технологии и условия</p>\n      <div class=\"space-y-8\" data-kid=\"105\">\n        <div data-kid=\"106\">\n          <label class=\"block text-sm font-semibold text-slate-400 mb-4 uppercase tracking-wider\" data-kid=\"107\">Стек технологий</label>\n          <div class=\"grid grid-cols-2 sm:grid-cols-4 gap-3\" data-kid=\"108\">\n            <button class=\"option-card p-4 rounded-2xl border border-white/5 text-center text-sm font-medium\" onclick=\"selectStack('react', this)\" data-kid=\"109\">React / Next.js</button>\n            <button class=\"option-card p-4 rounded-2xl border border-white/5 text-center text-sm font-medium\" onclick=\"selectStack('vue', this)\" data-kid=\"110\">Vue / Nuxt</button>\n            <button class=\"option-card p-4 rounded-2xl border border-white/5 text-center text-sm font-medium\" onclick=\"selectStack('python', this)\" data-kid=\"111\">Python / Django</button>\n            <button class=\"option-card p-4 rounded-2xl border border-white/5 text-center text-sm font-medium\" onclick=\"selectStack('node', this)\" data-kid=\"112\">Node.js</button>\n          </div>\n        </div>\n\n        <div class=\"space-y-4\" data-kid=\"113\">\n          <label class=\"flex items-center gap-4 cursor-pointer checkbox-container\" data-kid=\"114\">\n            <input type=\"checkbox\" id=\"design-needed\" class=\"hidden\" onchange=\"updateEstimates()\" data-kid=\"115\">\n            <div class=\"custom-checkbox\" data-kid=\"116\">\n              <span class=\"text-[10px] text-white\" data-kid=\"117\">✓</span>\n            </div>\n            <span class=\"text-slate-300 font-medium\" data-kid=\"118\">Мне нужен дизайн (UI/UX)</span>\n          </label>\n          <label class=\"flex items-center gap-4 cursor-pointer checkbox-container\" data-kid=\"119\">\n            <input type=\"checkbox\" id=\"urgent-deadline\" class=\"hidden\" onchange=\"updateEstimates()\" data-kid=\"120\">\n            <div class=\"custom-checkbox\" data-kid=\"121\">\n              <span class=\"text-[10px] text-white\" data-kid=\"122\">✓</span>\n            </div>\n            <span class=\"text-slate-300 font-medium\" data-kid=\"123\">Срочный проект (приоритет в очереди)</span>\n          </label>\n        </div>\n      </div>\n    </div>\n\n    \n    <div id=\"step-5\" class=\"step-content hidden fade-in\" data-kid=\"124\">\n      <div class=\"flex flex-col items-center mb-10\" data-kid=\"125\">\n        <div class=\"w-20 h-20 rounded-full bg-cyan-500/20 flex items-center justify-center mb-6\" data-kid=\"126\">\n          <span class=\"text-4xl\" data-kid=\"127\">💰</span>\n        </div>\n        <h3 class=\"text-2xl font-bold mb-2\" data-kid=\"128\">Ваша смета готова</h3>\n        <p class=\"text-slate-400 text-sm\" data-kid=\"129\">Предварительный расчет на основе ваших ответов</p>\n      </div>\n\n      <div class=\"grid md:grid-cols-2 gap-6 mb-10\" data-kid=\"130\">\n        <div class=\"p-8 rounded-[32px] bg-white/5 border border-white/10 flex flex-col items-center justify-center\" data-kid=\"131\">\n          <span class=\"text-xs uppercase tracking-widest text-slate-500 font-bold mb-2\" data-kid=\"132\">Бюджет</span>\n          <div class=\"text-3xl md:text-4xl font-black text-cyan-400\" id=\"final-price\" data-kid=\"133\">от 45,000 ₽</div>\n        </div>\n        <div class=\"p-8 rounded-[32px] bg-white/5 border border-white/10 flex flex-col items-center justify-center\" data-kid=\"134\">\n          <span class=\"text-xs uppercase tracking-widest text-slate-500 font-bold mb-2\" data-kid=\"135\">Сроки</span>\n          <div class=\"text-3xl md:text-4xl font-black\" id=\"final-days\" data-kid=\"136\">от 5 дней</div>\n        </div>\n      </div>\n\n      <div class=\"space-y-6\" data-kid=\"137\">\n        <h4 class=\"text-sm font-bold text-slate-400 uppercase tracking-widest\" data-kid=\"138\">Разбивка работ</h4>\n        <div class=\"space-y-4\" id=\"breakdown-list\" data-kid=\"139\">\n          \n        </div>\n      </div>\n    </div>\n\n    \n    <div class=\"mt-16 flex items-center justify-between\" data-kid=\"140\">\n      <button id=\"btn-back\" class=\"px-8 py-4 rounded-2xl border border-white/10 text-slate-400 font-semibold hover:bg-white/5 transition-all hidden\" onclick=\"goBack()\" data-kid=\"141\">\n        Назад\n      </button>\n      <button id=\"btn-next\" class=\"px-10 py-4 rounded-2xl btn-primary text-white font-bold ml-auto\" onclick=\"goNext()\" data-kid=\"142\">\n        Далее\n      </button>\n      <button id=\"btn-reset\" class=\"px-8 py-4 rounded-2xl border border-white/10 text-slate-400 font-semibold hover:bg-white/5 transition-all hidden\" onclick=\"reset()\" data-kid=\"143\">\n        Новый расчет\n      </button>\n    </div>\n  </div>\n</main>\n\n<script data-kid=\"144\">\n  let currentStep = 1;\n  const totalSteps = 5;\n  \n  const state = {\n    type: '',\n    complexity: '',\n    features: [],\n    stack: '',\n    design: false,\n    urgent: false\n  };\n\n  const data = {\n    complexityMap: {\n      landing: [\n        { value: 'simple', label: 'Простой', desc: '1 секция, без форм' },\n        { value: 'medium', label: 'Средний', desc: '3-5 секций, форма заявки' },\n        { value: 'complex', label: 'Продвинутый', desc: 'Анимации, калькулятор, интеграции' },\n      ],\n      corporate: [\n        { value: 'simple', label: 'Базовый', desc: '5-7 страниц, каталог' },\n        { value: 'medium', label: 'Стандарт', desc: '10-15 страниц, блог, формы' },\n        { value: 'complex', label: 'Расширенный', desc: 'Личный кабинет, интеграции' },\n      ],\n      webapp: [\n        { value: 'simple', label: 'MVP', desc: '1-2 основные функции' },\n        { value: 'medium', label: 'Стандарт', desc: '5-10 функций, роли пользователей' },\n        { value: 'complex', label: 'Платформа', desc: 'Модульная архитектура, API' },\n      ],\n      // Fallback\n      custom: [\n        { value: 'simple', label: 'Простой', desc: 'Базовый функционал' },\n        { value: 'medium', label: 'Средний', desc: 'Несколько модулей' },\n        { value: 'complex', label: 'Сложный', desc: 'Много интеграций' },\n      ]\n    },\n    basePrices: {\n      landing: 40000,\n      corporate: 80000,\n      ecommerce: 120000,\n      webapp: 200000,\n      mobile: 250000,\n      telegram: 50000,\n      crm: 150000,\n      api: 100000,\n      custom: 150000\n    },\n    baseDays: {\n      landing: 5,\n      corporate: 14,\n      ecommerce: 21,\n      webapp: 30,\n      mobile: 45,\n      telegram: 10,\n      crm: 25,\n      api: 15,\n      custom: 20\n    }\n  };\n\n  function selectType(type, el) {\n    state.type = type;\n    document.querySelectorAll('#step-1 .option-card').forEach(c => c.classList.remove('selected'));\n    el.classList.add('selected');\n    \n    // Update complexity descriptions\n    const map = data.complexityMap[type] || data.complexityMap.custom;\n    document.getElementById('complex-desc-simple').textContent = map[0].desc;\n    document.getElementById('complex-desc-medium').textContent = map[1].desc;\n    document.getElementById('complex-desc-complex').textContent = map[2].desc;\n  }\n\n  function selectComplexity(val, el) {\n    state.complexity = val;\n    document.querySelectorAll('#step-2 .option-card').forEach(c => c.classList.remove('selected'));\n    el.classList.add('selected');\n  }\n\n  function toggleFeature(el) {\n    el.classList.toggle('selected');\n    el.classList.toggle('bg-cyan-500/20');\n    el.classList.toggle('border-cyan-500/40');\n    \n    const feature = el.textContent;\n    if (state.features.includes(feature)) {\n      state.features = state.features.filter(f => f !== feature);\n    } else {\n      state.features.push(feature);\n    }\n  }\n\n  function selectStack(stack, el) {\n    state.stack = stack;\n    document.querySelectorAll('#step-4 .option-card').forEach(c => c.classList.remove('selected'));\n    el.classList.add('selected');\n  }\n\n  function goNext() {\n    if (currentStep < totalSteps) {\n      document.getElementById(`step-${currentStep}`).classList.add('hidden');\n      currentStep++;\n      document.getElementById(`step-${currentStep}`).classList.remove('hidden');\n      updateProgress();\n      \n      if (currentStep === totalSteps) {\n        calculate();\n        document.getElementById('btn-next').classList.add('hidden');\n        document.getElementById('btn-reset').classList.remove('hidden');\n      }\n      \n      if (currentStep > 1) {\n        document.getElementById('btn-back').classList.remove('hidden');\n      }\n    }\n  }\n\n  function goBack() {\n    if (currentStep > 1) {\n      document.getElementById(`step-${currentStep}`).classList.add('hidden');\n      currentStep--;\n      document.getElementById(`step-${currentStep}`).classList.remove('hidden');\n      updateProgress();\n      \n      if (currentStep < totalSteps) {\n        document.getElementById('btn-next').classList.remove('hidden');\n        document.getElementById('btn-reset').classList.add('hidden');\n      }\n      \n      if (currentStep === 1) {\n        document.getElementById('btn-back').classList.add('hidden');\n      }\n    }\n  }\n\n  function updateProgress() {\n    const progress = ((currentStep - 1) / (totalSteps - 1)) * 100;\n    document.getElementById('progress-bar').style.width = `${progress}%`;\n    \n    document.querySelectorAll('.step-dot').forEach(dot => {\n      const step = parseInt(dot.dataset.step);\n      if (step <= currentStep) {\n        dot.classList.add('active');\n      } else {\n        dot.classList.remove('active');\n      }\n    });\n  }\n\n  function calculate() {\n    state.design = document.getElementById('design-needed').checked;\n    state.urgent = document.getElementById('urgent-deadline').checked;\n\n    let base = data.basePrices[state.type] || 100000;\n    let days = data.baseDays[state.type] || 15;\n\n    // Complexity\n    const mult = state.complexity === 'complex' ? 2.5 : state.complexity === 'medium' ? 1.5 : 1;\n    base *= mult;\n    days *= mult;\n\n    // Features\n    base += state.features.length * 15000;\n    days += state.features.length * 2;\n\n    // Options\n    if (state.design) { base *= 1.3; days += 5; }\n    if (state.urgent) { base *= 1.5; days *= 0.7; }\n\n    document.getElementById('final-price').textContent = `от ${Math.round(base).toLocaleString('ru-RU')} ₽`;\n    document.getElementById('final-days').textContent = `от ${Math.round(days)} дней`;\n\n    // Breakdown\n    const list = document.getElementById('breakdown-list');\n    list.innerHTML = '';\n    \n    const stages = [\n      { name: 'Аналитика и ТЗ', pct: 15 },\n      { name: 'Дизайн UI/UX', pct: state.design ? 25 : 10 },\n      { name: 'Разработка Front-end', pct: 35 },\n      { name: 'Backend и API', pct: 20 },\n      { name: 'QA и Тестирование', pct: 10 }\n    ];\n\n    stages.forEach(s => {\n      const item = document.createElement('div');\n      item.className = 'space-y-2';\n      item.innerHTML = `\n        <div class=\"flex justify-between text-xs font-semibold\">\n          <span class=\"text-slate-400\">${s.name}</span>\n          <span>${s.pct}%</span>\n        </div>\n        <div class=\"h-1.5 w-full bg-white/5 rounded-full overflow-hidden\">\n          <div class=\"h-full bg-cyan-500 rounded-full\" style=\"width: ${s.pct}%\"></div>\n        </div>\n      `;\n      list.appendChild(item);\n    });\n  }\n\n  function reset() {\n    currentStep = 5;\n    goBack(); goBack(); goBack(); goBack();\n    document.querySelectorAll('.option-card').forEach(c => c.classList.remove('selected'));\n    document.querySelectorAll('.chip').forEach(c => {\n      c.classList.remove('selected', 'bg-cyan-500/20', 'border-cyan-500/40');\n    });\n    document.getElementById('description').value = '';\n    document.getElementById('design-needed').checked = false;\n    document.getElementById('urgent-deadline').checked = false;\n    state.features = [];\n  }\n</script>",
