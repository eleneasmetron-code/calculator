  "nodes": {
    "var_4bec004158db": {
      "type": "variant",
      "label": "v3-3: Bold Editorial Vision",
      "parentId": null,
      "themeId": null,
      "rect": {
        "x": 1540,
        "y": 0,
        "w": 1280,
        "h": 915
