      "generation": {
        "prompt": "",
        "config": {}
      },
      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,900;1,900&family=Plus+Jakarta+Sans:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap');\n\n  :root {\n    --accent: #2563eb;\n    --bg: #050505;\n    --fg: #ffffff;\n    --muted: #404040;\n    --border: rgba(255, 255, 255, 0.1);\n  }\n\n  body {\n    background-color: var(--bg);\n    color: var(--fg);\n    font-family: 'Plus Jakarta Sans', sans-serif;\n    margin: 0;\n    overflow-x: hidden;\n  }\n\n  .font-serif { font-family: 'Playfair Display', serif; font-weight: 900; }\n  .font-mono { font-family: 'JetBrains Mono', monospace; }\n\n  .container {\n    max-width: 1200px;\n    margin: 0 auto;\n    padding: 100px 40px;\n  }\n\n  .huge-title {\n    font-size: clamp(4rem, 10vw, 8rem);\n    line-height: 0.9;\n    margin-bottom: 60px;\n    text-transform: uppercase;\n    letter-spacing: -0.04em;\n  }\n\n  .editorial-line {\n    width: 100%;\n    height: 1px;\n    background: var(--border);\n    margin: 40px 0;\n  }\n\n  .conversational-box {\n    font-size: clamp(1.5rem, 4vw, 3rem);\n    line-height: 1.4;\n    font-weight: 500;\n  }\n\n  .interactive-word {\n    color: var(--accent);\n    text-decoration: underline;\n    text-underline-offset: 8px;\n    cursor: pointer;\n    transition: all 0.3s ease;\n    display: inline-block;\n    position: relative;\n  }\n\n  .interactive-word:hover {\n    color: #fff;\n    background: var(--accent);\n    text-decoration: none;\n  }\n\n  .step-section {\n    opacity: 0;\n    transform: translateY(40px);\n    display: none;\n  }\n\n  .step-section.active {\n    display: block;\n    opacity: 1;\n    transform: translateY(0);\n  }\n\n  .overlay {\n    position: fixed;\n    inset: 0;\n    background: rgba(0,0,0,0.95);\n    z-index: 100;\n    display: none;\n    align-items: center;\n    justify-content: center;\n    padding: 40px;\n    backdrop-filter: blur(10px);\n  }\n\n  .overlay-content {\n    max-width: 800px;\n    width: 100%;\n  }\n\n  .option-grid {\n    display: grid;\n    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));\n    gap: 20px;\n    margin-top: 40px;\n  }\n\n  .option-card {\n    border: 1px solid var(--border);\n    padding: 30px;\n    transition: all 0.3s ease;\n    cursor: pointer;\n  }\n\n  .option-card:hover, .option-card.selected {\n    background: var(--fg);\n    color: var(--bg);\n  }\n\n  .option-card.selected .check { display: block; }\n  .check { display: none; font-size: 1.2rem; margin-top: 10px; }\n\n  .btn-editorial {\n    display: inline-block;\n    padding: 20px 60px;\n    background: var(--accent);\n    color: white;\n    font-weight: 700;\n    text-transform: uppercase;\n    letter-spacing: 0.1em;\n    cursor: pointer;\n    border: none;\n    transition: all 0.3s ease;\n    margin-top: 40px;\n  }\n\n  .btn-editorial:hover {\n    filter: brightness(1.2);\n    transform: translateX(10px);\n  }\n\n  .invoice-card {\n    border: 1px solid var(--border);\n    padding: 60px;\n    margin-top: 60px;\n  }\n\n  .invoice-header {\n    display: flex;\n    justify-content: space-between;\n    align-items: flex-end;\n    margin-bottom: 60px;\n  }\n\n  .invoice-price {\n    font-size: 6rem;\n    color: var(--accent);\n    line-height: 1;\n  }\n\n  .tag {\n    font-size: 0.8rem;\n    text-transform: uppercase;\n    letter-spacing: 0.2em;\n    color: var(--muted);\n    margin-bottom: 10px;\n    display: block;\n  }\n\n  /* Custom Checkbox/Toggle styling */\n  .custom-checkbox {\n    display: flex;\n    align-items: center;\n    gap: 15px;\n    margin-bottom: 15px;\n    cursor: pointer;\n  }\n  .custom-checkbox .box {\n    width: 20px;\n    height: 20px;\n    border: 1px solid var(--border);\n    display: flex;\n    align-items: center;\n    justify-content: center;\n  }\n  .custom-checkbox.active .box { background: var(--accent); border-color: var(--accent); }\n\n  textarea.editorial-input {\n    width: 100%;\n    background: transparent;\n    border: none;\n    border-bottom: 1px solid var(--border);\n    color: var(--fg);\n    font-size: 2rem;\n    padding: 20px 0;\n    outline: none;\n    font-family: inherit;\n    resize: none;\n  }\n\n  .file-drop {\n    border: 1px dashed var(--border);\n    padding: 40px;\n    text-align: center;\n    margin: 20px 0;\n    color: var(--muted);\n    font-size: 0.9rem;\n    text-transform: uppercase;\n  }\n\n  .nav-dots {\n    position: fixed;\n    right: 40px;\n    top: 50%;\n    transform: translateY(-50%);\n    display: flex;\n    flex-direction: column;\n    gap: 15px;\n    z-index: 50;\n  }\n\n  .dot {\n    width: 8px;\n    height: 8px;\n    border-radius: 50%;\n    background: var(--muted);\n    transition: all 0.3s ease;\n  }\n\n  .dot.active {\n    background: var(--accent);\n    transform: scale(1.5);\n  }\n</style>\n\n<div class=\"container\" data-kid=\"1\">\n  <div class=\"huge-title font-serif\" data-kid=\"2\">\n    Visionary<br data-kid=\"3\">Engineering<br data-kid=\"4\"><span style=\"color:var(--accent)\" data-kid=\"5\">Estimator</span>\n  </div>\n\n  <div class=\"editorial-line\" data-kid=\"6\"></div>\n\n  \n  <div class=\"nav-dots\" data-kid=\"7\">\n    <div class=\"dot active\" data-step=\"1\" data-kid=\"8\"></div>\n    <div class=\"dot\" data-step=\"2\" data-kid=\"9\"></div>\n    <div class=\"dot\" data-step=\"3\" data-kid=\"10\"></div>\n    <div class=\"dot\" data-step=\"4\" data-kid=\"11\"></div>\n  </div>\n\n  \n  <div id=\"step-1\" class=\"step-section active\" data-kid=\"12\">\n    <span class=\"tag\" data-kid=\"13\">Шаг 01 — Концепция</span>\n    <div class=\"conversational-box\" data-kid=\"14\">\n      Я хочу спроектировать \n      <span class=\"interactive-word\" id=\"trigger-type\" onclick=\"openOverlay('overlay-type')\" data-kid=\"15\">Лендинг</span> \n      высокой \n      <span class=\"interactive-word\" id=\"trigger-complexity\" onclick=\"openOverlay('overlay-complexity')\" data-kid=\"16\">Средний</span>\n      сложности.\n    </div>\n    <button class=\"btn-editorial\" onclick=\"nextStep(2)\" data-kid=\"17\">Продолжить →</button>\n  </div>\n\n  \n  <div id=\"step-2\" class=\"step-section\" data-kid=\"18\">\n    <span class=\"tag\" data-kid=\"19\">Шаг 02 — Функционал</span>\n    <div class=\"conversational-box\" data-kid=\"20\">\n      Суть проекта заключается в следующем:<br data-kid=\"21\">\n      <textarea class=\"editorial-input\" id=\"description\" placeholder=\"Опишите ваш вижн...\" data-kid=\"22\"></textarea>\n      <div class=\"file-drop\" id=\"drop-zone\" data-kid=\"23\">Перетащите ТЗ или нажмите для выбора</div>\n      Мне также необходимы \n      <span class=\"interactive-word\" id=\"trigger-features\" onclick=\"openOverlay('overlay-features')\" data-kid=\"24\">Выбранные функции</span>.\n    </div>\n    <button class=\"btn-editorial\" onclick=\"nextStep(3)\" data-kid=\"25\">Стек технологий →</button>\n  </div>\n\n  \n  <div id=\"step-3\" class=\"step-section\" data-kid=\"26\">\n    <span class=\"tag\" data-kid=\"27\">Шаг 03 — Архитектура</span>\n    <div class=\"conversational-box\" data-kid=\"28\">\n      Мы будем использовать \n      <span class=\"interactive-word\" id=\"trigger-tech\" onclick=\"openOverlay('overlay-tech')\" data-kid=\"29\">React / Next.js</span> \n      в качестве основного стека.<br data-kid=\"30\">\n      <div style=\"margin-top: 30px;\" data-kid=\"31\">\n        <div class=\"custom-checkbox\" onclick=\"toggleOption('designNeeded')\" data-kid=\"32\">\n          <div class=\"box\" data-kid=\"33\"></div> <span style=\"font-size: 1rem; text-transform: uppercase;\" data-kid=\"34\">Нужен профессиональный дизайн UI/UX</span>\n        </div>\n        <div class=\"custom-checkbox\" onclick=\"toggleOption('urgentDeadline')\" data-kid=\"35\">\n          <div class=\"box\" data-kid=\"36\"></div> <span style=\"font-size: 1rem; text-transform: uppercase;\" data-kid=\"37\">Срочный проект (приоритет в очереди)</span>\n        </div>\n      </div>\n    </div>\n    <button class=\"btn-editorial\" onclick=\"calculateFinal()\" data-kid=\"38\">Компилировать смету →</button>\n  </div>\n\n  \n  <div id=\"step-4\" class=\"step-section\" data-kid=\"39\">\n    <span class=\"tag\" data-kid=\"40\">Итоговая Смета</span>\n    <div class=\"invoice-card\" data-kid=\"41\">\n      <div class=\"invoice-header\" data-kid=\"42\">\n        <div data-kid=\"43\">\n          <div class=\"font-serif\" style=\"font-size: 2rem;\" data-kid=\"44\">Bespoke Vision</div>\n          <div class=\"font-mono\" style=\"font-size: 0.8rem; color: var(--muted); margin-top: 5px;\" data-kid=\"45\">EST_REF: VIBE-2026-06</div>\n        </div>\n        <div class=\"font-mono\" style=\"text-align: right;\" data-kid=\"46\">\n          <div id=\"res-type\" data-kid=\"47\">ЛЕНДИНГ</div>\n          <div id=\"res-complexity\" style=\"color: var(--muted);\" data-kid=\"48\">СРЕДНЯЯ СЛОЖНОСТЬ</div>\n        </div>\n      </div>\n\n      <div class=\"tag\" data-kid=\"49\">Ориентировочный Бюджет</div>\n      <div class=\"invoice-price font-serif\" id=\"res-price\" data-kid=\"50\">250,000₽</div>\n\n      <div class=\"editorial-line\" data-kid=\"51\"></div>\n\n      <div style=\"display: grid; grid-template-columns: 1fr 1fr; gap: 40px;\" data-kid=\"52\">\n        <div data-kid=\"53\">\n          <div class=\"tag\" data-kid=\"54\">Сроки реализации</div>\n          <div style=\"font-size: 2rem;\" id=\"res-days\" data-kid=\"55\">14 — 21 ДЕНЬ</div>\n        </div>\n        <div data-kid=\"56\">\n          <div class=\"tag\" data-kid=\"57\">Технологический стек</div>\n          <div style=\"font-size: 1.2rem; text-transform: uppercase;\" id=\"res-tech\" data-kid=\"58\">REACT / NEXT.JS</div>\n        </div>\n      </div>\n\n      <div class=\"editorial-line\" data-kid=\"59\"></div>\n\n      <div class=\"tag\" data-kid=\"60\">Рекомендации Архитектора</div>\n      <ul id=\"res-recs\" style=\"list-style: none; padding: 0; font-size: 1rem; line-height: 1.8; color: #ccc;\" data-kid=\"61\">\n      </ul>\n\n      <button class=\"btn-editorial\" style=\"width: 100%; margin-top: 60px;\" data-kid=\"62\">Запустить производство →</button>\n    </div>\n  </div>\n</div>\n\n\n<div id=\"overlay-type\" class=\"overlay\" data-kid=\"63\">\n  <div class=\"overlay-content\" data-kid=\"64\">\n    <div class=\"font-serif\" style=\"font-size: 3rem;\" data-kid=\"65\">Выберите тип проекта</div>\n    <div class=\"option-grid\" id=\"grid-type\" data-kid=\"66\"></div>\n    <button class=\"btn-editorial\" onclick=\"closeOverlay()\" data-kid=\"67\">Готово</button>\n  </div>\n</div>\n\n<div id=\"overlay-complexity\" class=\"overlay\" data-kid=\"68\">\n  <div class=\"overlay-content\" data-kid=\"69\">\n    <div class=\"font-serif\" style=\"font-size: 3rem;\" data-kid=\"70\">Уровень сложности</div>\n    <div class=\"option-grid\" id=\"grid-complexity\" data-kid=\"71\"></div>\n    <button class=\"btn-editorial\" onclick=\"closeOverlay()\" data-kid=\"72\">Готово</button>\n  </div>\n</div>\n\n<div id=\"overlay-features\" class=\"overlay\" data-kid=\"73\">\n  <div class=\"overlay-content\" data-kid=\"74\">\n    <div class=\"font-serif\" style=\"font-size: 3rem;\" data-kid=\"75\">Выберите модули</div>\n    <div class=\"option-grid\" id=\"grid-features\" data-kid=\"76\"></div>\n    <button class=\"btn-editorial\" onclick=\"closeOverlay()\" data-kid=\"77\">Готово</button>\n  </div>\n</div>\n\n<div id=\"overlay-tech\" class=\"overlay\" data-kid=\"78\">\n  <div class=\"overlay-content\" data-kid=\"79\">\n    <div class=\"font-serif\" style=\"font-size: 3rem;\" data-kid=\"80\">Выберите стек</div>\n    <div class=\"option-grid\" id=\"grid-tech\" data-kid=\"81\"></div>\n    <button class=\"btn-editorial\" onclick=\"closeOverlay()\" data-kid=\"82\">Готово</button>\n  </div>\n</div>\n\n<script src=\"https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js\" data-kid=\"83\"></script>\n<script data-kid=\"84\">\n  const PROJECT_TYPES = [\n    { value: 'landing', label: 'Лендинг', base: 50000, days: 7 },\n    { value: 'corporate', label: 'Корпоративный сайт', base: 120000, days: 20 },\n    { value: 'ecommerce', label: 'Интернет-магазин', base: 180000, days: 30 },\n    { value: 'webapp', label: 'Веб-приложение', base: 250000, days: 45 },\n    { value: 'mobile', label: 'Мобильное приложение', base: 300000, days: 60 },\n    { value: 'telegram', label: 'Telegram бот', base: 40000, days: 10 },\n    { value: 'crm', label: 'CRM / Админ-панель', base: 200000, days: 40 },\n    { value: 'api', label: 'API / Backend', base: 150000, days: 25 },\n    { value: 'custom', label: 'Своё / Другое', base: 100000, days: 20 },\n  ];\n\n  const COMPLEXITY = [\n    { value: 'simple', label: 'Простой', mult: 0.8 },\n    { value: 'medium', label: 'Средний', mult: 1.2 },\n    { value: 'complex', label: 'Продвинутый', mult: 2.0 },\n  ];\n\n  const FEATURES = [\n    'Авторизация', 'Оплата онлайн', 'CRM Интеграция', 'Уведомления', \n    'Админка', 'Поиск', 'Файлы', 'Мультиязычность', 'Аналитика'\n  ];\n\n  const TECH = [\n    'React / Next.js', 'Vue / Nuxt', 'Python / Django', 'Node.js', 'PHP / Laravel', 'Flutter', 'WordPress'\n  ];\n\n  let state = {\n    type: 'landing',\n    complexity: 'medium',\n    features: [],\n    tech: 'React / Next.js',\n    designNeeded: false,\n    urgentDeadline: false\n  };\n\n  function openOverlay(id) {\n    document.getElementById(id).style.display = 'flex';\n    gsap.from(`#${id} .overlay-content`, { y: 100, opacity: 0, duration: 0.6, ease: 'power4.out' });\n  }\n\n  function closeOverlay() {\n    gsap.to('.overlay', { opacity: 0, duration: 0.3, onComplete: () => {\n      document.querySelectorAll('.overlay').forEach(el => el.style.display = 'none');\n      document.querySelectorAll('.overlay').forEach(el => el.style.opacity = '1');\n    }});\n    updateTriggers();\n  }\n\n  function selectType(val) {\n    state.type = val;\n    renderGrids();\n    updateTriggers();\n  }\n\n  function selectComplexity(val) {\n    state.complexity = val;\n    renderGrids();\n    updateTriggers();\n  }\n\n  function selectTech(val) {\n    state.tech = val;\n    renderGrids();\n    updateTriggers();\n  }\n\n  function toggleFeature(val) {\n    if (state.features.includes(val)) {\n      state.features = state.features.filter(f => f !== val);\n    } else {\n      state.features.push(val);\n    }\n    renderGrids();\n    updateTriggers();\n  }\n\n  function toggleOption(opt) {\n    state[opt] = !state[opt];\n    const el = document.querySelector(`.custom-checkbox[onclick=\"toggleOption('${opt}')\"]`);\n    el.classList.toggle('active');\n  }\n\n  function updateTriggers() {\n    document.getElementById('trigger-type').innerText = PROJECT_TYPES.find(t => t.value === state.type).label;\n    document.getElementById('trigger-complexity').innerText = COMPLEXITY.find(c => c.value === state.complexity).label;\n    document.getElementById('trigger-tech').innerText = state.tech;\n    document.getElementById('trigger-features').innerText = state.features.length > 0 ? `Функций: ${state.features.length}` : 'Выбранные функции';\n  }\n\n  function renderGrids() {\n    // Type Grid\n    document.getElementById('grid-type').innerHTML = PROJECT_TYPES.map(t => `\n      <div class=\"option-card ${state.type === t.value ? 'selected' : ''}\" onclick=\"selectType('${t.value}')\">\n        <div class=\"font-mono\" style=\"font-size: 0.7rem; color: var(--muted); margin-bottom: 10px;\">${t.value.toUpperCase()}</div>\n        <div style=\"font-size: 1.2rem; font-weight: 700;\">${t.label}</div>\n      </div>\n    `).join('');\n\n    // Complexity Grid\n    document.getElementById('grid-complexity').innerHTML = COMPLEXITY.map(c => `\n      <div class=\"option-card ${state.complexity === c.value ? 'selected' : ''}\" onclick=\"selectComplexity('${c.value}')\">\n        <div style=\"font-size: 1.2rem; font-weight: 700;\">${c.label}</div>\n      </div>\n    `).join('');\n\n    // Features Grid\n    document.getElementById('grid-features').innerHTML = FEATURES.map(f => `\n      <div class=\"option-card ${state.features.includes(f) ? 'selected' : ''}\" onclick=\"toggleFeature('${f}')\">\n        <div style=\"font-size: 1.1rem; font-weight: 700;\">${f}</div>\n      </div>\n    `).join('');\n\n    // Tech Grid\n    document.getElementById('grid-tech').innerHTML = TECH.map(t => `\n      <div class=\"option-card ${state.tech === t ? 'selected' : ''}\" onclick=\"selectTech('${t}')\">\n        <div style=\"font-size: 1.1rem; font-weight: 700;\">${t}</div>\n      </div>\n    `).join('');\n  }\n\n  function nextStep(n) {\n    gsap.to(`#step-${n-1}`, { opacity: 0, y: -20, duration: 0.4, onComplete: () => {\n      document.getElementById(`step-${n-1}`).classList.remove('active');\n      const next = document.getElementById(`step-${n}`);\n      next.classList.add('active');\n      gsap.fromTo(next, { opacity: 0, y: 40 }, { opacity: 1, y: 0, duration: 0.6, ease: 'power4.out' });\n      \n      document.querySelectorAll('.dot').forEach(d => d.classList.remove('active'));\n      document.querySelector(`.dot[data-step=\"${n}\"]`).classList.add('active');\n    }});\n  }\n\n  function calculateFinal() {\n    const typeObj = PROJECT_TYPES.find(t => t.value === state.type);\n    const compObj = COMPLEXITY.find(c => c.value === state.complexity);\n    \n    let base = typeObj.base * compObj.mult;\n    let days = typeObj.days * compObj.mult;\n    \n    // Add features\n    base += state.features.length * 15000;\n    days += state.features.length * 2;\n    \n    if (state.designNeeded) base += 40000;\n    if (state.urgentDeadline) {\n      base *= 1.4;\n      days *= 0.7;\n    }\n\n    document.getElementById('res-type').innerText = typeObj.label.toUpperCase();\n    document.getElementById('res-complexity').innerText = `${compObj.label.toUpperCase()} УРОВЕНЬ`;\n    document.getElementById('res-price').innerText = Math.round(base).toLocaleString() + '₽';\n    document.getElementById('res-days').innerText = `${Math.round(days * 0.8)} — ${Math.round(days * 1.2)} ДНЕЙ`;\n    document.getElementById('res-tech').innerText = state.tech;\n    \n    const recs = [\n      \"Использование модульной архитектуры для масштабируемости.\",\n      \"Оптимизация производительности (Lighthouse 90+).\",\n      \"Чистый код по стандартам индустрии.\"\n    ];\n    if (state.tech.includes('Next.js')) recs.push(\"SSR/ISR для идеального SEO.\");\n    \n    document.getElementById('res-recs').innerHTML = recs.map(r => `<li>— ${r}</li>`).join('');\n\n    nextStep(4);\n  }\n\n  // Init\n  renderGrids();\n  updateTriggers();\n</script>",
