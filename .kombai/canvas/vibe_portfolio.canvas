      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Geist+Mono:wght@100..900&family=Plus+Jakarta+Sans:wght@200..800&family=JetBrains+Mono:wght@100..800&display=swap');\n\n  :root {\n    --arch-black: #000000;\n    --arch-gray-900: #0a0a0a;\n    --arch-gray-800: #141414;\n    --arch-gray-700: #1a1a1a;\n    --arch-cyan: #22d3ee;\n    --arch-slate: #475569;\n    --arch-border: rgba(255, 255, 255, 0.08);\n  }\n\n  body {\n    background-color: var(--arch-black);\n    color: #e2e8f0;\n    font-family: 'Plus Jakarta Sans', sans-serif;\n    margin: 0;\n    overflow-x: hidden;\n  }\n\n  .font-mono { font-family: 'Geist Mono', monospace; }\n  .font-heading { font-family: 'Plus Jakarta Sans', sans-serif; }\n\n  /* Background Grid */\n  .arch-grid {\n    background-image: linear-gradient(var(--arch-border) 1px, transparent 1px),\n                      linear-gradient(90deg, var(--arch-border) 1px, transparent 1px);\n    background-size: 40px 40px;\n    position: fixed;\n    inset: 0;\n    z-index: -1;\n    pointer-events: none;\n  }\n\n  /* Technical Markers */\n  .marker {\n    position: fixed;\n    font-family: 'Geist Mono', monospace;\n    font-size: 10px;\n    color: var(--arch-slate);\n    text-transform: uppercase;\n    letter-spacing: 0.1em;\n    z-index: 50;\n  }\n  .marker-tl { top: 20px; left: 20px; border-left: 1px solid var(--arch-cyan); border-top: 1px solid var(--arch-cyan); padding: 5px; }\n  .marker-tr { top: 20px; right: 20px; border-right: 1px solid var(--arch-cyan); border-top: 1px solid var(--arch-cyan); padding: 5px; text-align: right; }\n  .marker-bl { bottom: 20px; left: 20px; border-left: 1px solid var(--arch-cyan); border-bottom: 1px solid var(--arch-cyan); padding: 5px; }\n  .marker-br { bottom: 20px; right: 20px; border-right: 1px solid var(--arch-cyan); border-bottom: 1px solid var(--arch-cyan); padding: 5px; text-align: right; }\n\n  /* Layout */\n  .main-container {\n    display: flex;\n    min-height: 900px;\n    max-width: 1200px;\n    margin: 60px auto;\n    border: 1px solid var(--arch-border);\n    position: relative;\n    background: var(--arch-gray-900);\n  }\n\n  /* Sidebar Navigation */\n  .nav-sidebar {\n    width: 280px;\n    border-right: 1px solid var(--arch-border);\n    padding: 40px 0;\n    background: rgba(10, 10, 10, 0.8);\n    backdrop-filter: blur(10px);\n  }\n\n  .nav-item {\n    padding: 15px 30px;\n    display: flex;\n    align-items: center;\n    gap: 15px;\n    opacity: 0.3;\n    transition: all 0.3s ease;\n    cursor: default;\n    border-left: 3px solid transparent;\n  }\n\n  .nav-item.active {\n    opacity: 1;\n    background: rgba(34, 211, 238, 0.05);\n    border-left: 3px solid var(--arch-cyan);\n  }\n\n  .nav-item.completed {\n    opacity: 0.6;\n  }\n\n  .nav-number {\n    font-family: 'Geist Mono', monospace;\n    font-size: 12px;\n    color: var(--arch-cyan);\n  }\n\n  .nav-label {\n    font-size: 13px;\n    text-transform: uppercase;\n    font-weight: 600;\n    letter-spacing: 0.05em;\n  }\n\n  /* Main Content Area */\n  .content-area {\n    flex: 1;\n    padding: 60px;\n    position: relative;\n    overflow-y: auto;\n  }\n\n  .step-header {\n    margin-bottom: 40px;\n  }\n\n  .step-title {\n    font-family: 'Plus Jakarta Sans', sans-serif;\n    font-size: 32px;\n    font-weight: 800;\n    margin: 0 0 10px 0;\n    color: #fff;\n    letter-spacing: -0.02em;\n  }\n\n  .step-subtitle {\n    font-size: 14px;\n    color: var(--arch-slate);\n    text-transform: uppercase;\n    letter-spacing: 0.1em;\n  }\n\n  /* Grid of cards */\n  .arch-grid-cards {\n    display: grid;\n    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));\n    gap: 1px;\n    background: var(--arch-border);\n    border: 1px solid var(--arch-border);\n  }\n\n  .arch-card {\n    background: var(--arch-gray-900);\n    padding: 25px;\n    cursor: pointer;\n    transition: all 0.2s ease;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    text-align: center;\n    border: 1px solid transparent;\n  }\n\n  .arch-card:hover {\n    background: var(--arch-gray-800);\n  }\n\n  .arch-card.selected {\n    border-color: var(--arch-cyan);\n    background: rgba(34, 211, 238, 0.02);\n    box-shadow: inset 0 0 15px rgba(34, 211, 238, 0.05);\n  }\n\n  .arch-card-icon {\n    font-size: 28px;\n    margin-bottom: 15px;\n    opacity: 0.8;\n  }\n\n  .arch-card-label {\n    font-size: 13px;\n    font-weight: 600;\n    text-transform: uppercase;\n    letter-spacing: 0.05em;\n  }\n\n  /* Inputs */\n  .arch-input-group {\n    margin-bottom: 30px;\n  }\n\n  .arch-label {\n    display: block;\n    font-size: 11px;\n    text-transform: uppercase;\n    color: var(--arch-slate);\n    letter-spacing: 0.15em;\n    margin-bottom: 12px;\n    font-family: 'Geist Mono', monospace;\n  }\n\n  .arch-textarea {\n    width: 100%;\n    background: var(--arch-gray-800);\n    border: 1px solid var(--arch-border);\n    color: #fff;\n    padding: 20px;\n    font-family: inherit;\n    font-size: 15px;\n    resize: none;\n    transition: all 0.3s ease;\n    outline: none;\n    box-sizing: border-box;\n  }\n\n  .arch-textarea:focus {\n    border-color: var(--arch-cyan);\n    background: var(--arch-gray-700);\n  }\n\n  /* Buttons */\n  .arch-btn-group {\n    display: flex;\n    justify-content: flex-end;\n    gap: 20px;\n    margin-top: 50px;\n    padding-top: 30px;\n    border-top: 1px solid var(--arch-border);\n  }\n\n  .arch-btn {\n    padding: 14px 28px;\n    font-family: 'Geist Mono', monospace;\n    font-size: 13px;\n    text-transform: uppercase;\n    letter-spacing: 0.1em;\n    cursor: pointer;\n    transition: all 0.2s ease;\n    border: 1px solid var(--arch-border);\n    background: transparent;\n    color: #fff;\n  }\n\n  .arch-btn:hover {\n    background: rgba(255, 255, 255, 0.05);\n    border-color: #fff;\n  }\n\n  .arch-btn-primary {\n    background: var(--arch-cyan);\n    color: var(--arch-black);\n    border-color: var(--arch-cyan);\n    font-weight: 700;\n  }\n\n  .arch-btn-primary:hover {\n    background: #fff;\n    color: var(--arch-black);\n    border-color: #fff;\n    box-shadow: 0 0 20px rgba(34, 211, 238, 0.3);\n  }\n\n  .arch-btn:disabled {\n    opacity: 0.2;\n    cursor: not-allowed;\n  }\n\n  /* Results Table */\n  .arch-spec-table {\n    width: 100%;\n    border-collapse: collapse;\n    margin-top: 20px;\n  }\n\n  .arch-spec-table th {\n    text-align: left;\n    padding: 15px;\n    font-family: 'Geist Mono', monospace;\n    font-size: 11px;\n    color: var(--arch-slate);\n    border-bottom: 1px solid var(--arch-border);\n    text-transform: uppercase;\n  }\n\n  .arch-spec-table td {\n    padding: 20px 15px;\n    border-bottom: 1px solid var(--arch-border);\n    font-size: 14px;\n  }\n\n  .price-highlight {\n    font-family: 'Geist Mono', monospace;\n    font-size: 24px;\n    color: var(--arch-cyan);\n    font-weight: 700;\n  }\n\n  /* Timeline Chart */\n  .arch-timeline {\n    margin-top: 40px;\n    border: 1px solid var(--arch-border);\n    background: var(--arch-gray-800);\n    padding: 30px;\n  }\n\n  .timeline-bar-container {\n    height: 30px;\n    background: rgba(255, 255, 255, 0.05);\n    margin-bottom: 10px;\n    display: flex;\n    align-items: center;\n    position: relative;\n  }\n\n  .timeline-bar {\n    height: 100%;\n    background: var(--arch-cyan);\n    position: absolute;\n    left: 0;\n    transition: width 1s ease;\n  }\n\n  .timeline-label {\n    position: absolute;\n    left: 10px;\n    z-index: 10;\n    font-size: 10px;\n    font-family: 'Geist Mono', monospace;\n    text-transform: uppercase;\n    color: #fff;\n  }\n\n  /* Feature chips */\n  .arch-chips {\n    display: flex;\n    flex-wrap: wrap;\n    gap: 10px;\n  }\n\n  .arch-chip {\n    padding: 10px 18px;\n    border: 1px solid var(--arch-border);\n    background: var(--arch-gray-800);\n    font-size: 12px;\n    cursor: pointer;\n    transition: all 0.2s ease;\n  }\n\n  .arch-chip.selected {\n    border-color: var(--arch-cyan);\n    background: rgba(34, 211, 238, 0.1);\n    color: var(--arch-cyan);\n  }\n\n  .hidden { display: none; }\n\n  /* Animations */\n  @keyframes typing {\n    from { width: 0 }\n    to { width: 100% }\n  }\n\n  .typing-effect {\n    overflow: hidden;\n    white-space: nowrap;\n    display: inline-block;\n    animation: typing 0.8s steps(40, end);\n  }\n\n  /* Scrollbar Customization */\n  ::-webkit-scrollbar { width: 4px; }\n  ::-webkit-scrollbar-track { background: var(--arch-black); }\n  ::-webkit-scrollbar-thumb { background: var(--arch-slate); }\n  ::-webkit-scrollbar-thumb:hover { background: var(--arch-cyan); }\n</style>\n\n<div class=\"arch-grid\" data-kid=\"1\"></div>\n\n\n<div class=\"marker marker-tl\" data-kid=\"2\">\n  VIBE_SYSTEM // ACTIVE<br data-kid=\"3\">\n  PRC: ARCH_V3.2\n</div>\n<div class=\"marker marker-tr\" data-kid=\"4\">\n  LOCATION: EARTH<br data-kid=\"5\">\n  TIME: <span id=\"clock-display\" data-kid=\"6\">00:00:00</span>\n</div>\n<div class=\"marker marker-bl\" data-kid=\"7\">\n  SCALE: 1:1<br data-kid=\"8\">\n  UNITS: RUBLE (RUB)\n</div>\n<div class=\"marker marker-br\" data-kid=\"9\">\n  ESTIMATOR_ENG // v0.1.0<br data-kid=\"10\">\n  COMPILING_PROTOCOLS...\n</div>\n\n<div class=\"main-container\" data-kid=\"11\">\n  \n  <aside class=\"nav-sidebar\" data-kid=\"12\">\n    <div class=\"nav-item active\" id=\"nav-1\" data-kid=\"13\">\n      <span class=\"nav-number\" data-kid=\"14\">01</span>\n      <span class=\"nav-label\" data-kid=\"15\">Классификация</span>\n    </div>\n    <div class=\"nav-item\" id=\"nav-2\" data-kid=\"16\">\n      <span class=\"nav-number\" data-kid=\"17\">02</span>\n      <span class=\"nav-label\" data-kid=\"18\">Сложность</span>\n    </div>\n    <div class=\"nav-item\" id=\"nav-3\" data-kid=\"19\">\n      <span class=\"nav-number\" data-kid=\"20\">03</span>\n      <span class=\"nav-label\" data-kid=\"21\">Спецификация</span>\n    </div>\n    <div class=\"nav-item\" id=\"nav-4\" data-kid=\"22\">\n      <span class=\"nav-number\" data-kid=\"23\">04</span>\n      <span class=\"nav-label\" data-kid=\"24\">Технологии</span>\n    </div>\n    <div class=\"nav-item\" id=\"nav-5\" data-kid=\"25\">\n      <span class=\"nav-number\" data-kid=\"26\">05</span>\n      <span class=\"nav-label\" data-kid=\"27\">Протокол</span>\n    </div>\n\n    <div style=\"margin-top: auto; padding: 40px 30px; font-family: 'Geist Mono', monospace; font-size: 10px; color: var(--arch-slate);\" data-kid=\"28\">\n      <div style=\"margin-bottom: 10px; border-top: 1px solid var(--arch-border); padding-top: 10px;\" data-kid=\"29\">\n        STATUS: OK<br data-kid=\"30\">\n        LATENCY: 12ms<br data-kid=\"31\">\n        MEMORY: 48.2MB\n      </div>\n      <div id=\"vibe-monitor\" style=\"color: var(--arch-cyan); opacity: 0.8;\" data-kid=\"32\">VIBE_LEVEL: 100%</div>\n    </div>\n  </aside>\n\n  \n  <main class=\"content-area\" data-kid=\"33\">\n    \n    <div id=\"step-1\" class=\"step-container\" data-kid=\"34\">\n      <div class=\"step-header\" data-kid=\"35\">\n        <div class=\"step-subtitle\" data-kid=\"36\">Шаг 01 // Выберите класс системы</div>\n        <h1 class=\"step-title\" id=\"title-1\" data-kid=\"37\">Тип проекта</h1>\n      </div>\n      \n      <div class=\"arch-grid-cards\" id=\"project-type-grid\" data-kid=\"38\">\n        \n      </div>\n      \n      <div class=\"arch-input-group\" id=\"custom-type-container\" style=\"display:none; margin-top: 25px;\" data-kid=\"39\">\n        <label class=\"arch-label\" data-kid=\"40\">Своё описание типа</label>\n        <input type=\"text\" id=\"custom-type-input\" class=\"arch-textarea\" style=\"padding: 12px 20px;\" placeholder=\"Введите тип проекта...\" data-kid=\"41\">\n      </div>\n    </div>\n\n    \n    <div id=\"step-2\" class=\"step-container hidden\" data-kid=\"42\">\n      <div class=\"step-header\" data-kid=\"43\">\n        <div class=\"step-subtitle\" data-kid=\"44\">Шаг 02 // Вычислите уровень исполнения</div>\n        <h1 class=\"step-title\" id=\"title-2\" data-kid=\"45\">Уровень сложности</h1>\n      </div>\n      \n      <div class=\"space-y-1\" id=\"complexity-list\" data-kid=\"46\">\n        \n      </div>\n    </div>\n\n    \n    <div id=\"step-3\" class=\"step-container hidden\" data-kid=\"47\">\n      <div class=\"step-header\" data-kid=\"48\">\n        <div class=\"step-subtitle\" data-kid=\"49\">Шаг 03 // Параметры спецификации</div>\n        <h1 class=\"step-title\" id=\"title-3\" data-kid=\"50\">Описание и функции</h1>\n      </div>\n      \n      <div class=\"arch-input-group\" data-kid=\"51\">\n        <label class=\"arch-label\" data-kid=\"52\">Подробное описание проекта</label>\n        <textarea id=\"project-description\" class=\"arch-textarea\" rows=\"5\" placeholder=\"Опишите задачи, экраны и требования...\" data-kid=\"53\"></textarea>\n      </div>\n\n      <div class=\"arch-input-group\" data-kid=\"54\">\n        <label class=\"arch-label\" data-kid=\"55\">Выбор функциональных модулей</label>\n        <div class=\"arch-chips\" id=\"feature-chips\" data-kid=\"56\">\n          \n        </div>\n      </div>\n\n      <div class=\"arch-input-group\" data-kid=\"57\">\n        <label class=\"arch-label\" data-kid=\"58\">Дополнительные кастомные функции</label>\n        <div style=\"display: flex; gap: 10px; margin-bottom: 15px;\" data-kid=\"59\">\n          <input type=\"text\" id=\"custom-feature-input\" class=\"arch-textarea\" style=\"padding: 12px 20px;\" placeholder=\"Название функции...\" data-kid=\"60\">\n          <button class=\"arch-btn\" style=\"padding: 0 25px;\" id=\"add-feature-btn\" data-kid=\"61\">+</button>\n        </div>\n        <div class=\"arch-chips\" id=\"custom-feature-chips\" data-kid=\"62\">\n          \n        </div>\n      </div>\n    </div>\n\n    \n    <div id=\"step-4\" class=\"step-container hidden\" data-kid=\"63\">\n      <div class=\"step-header\" data-kid=\"64\">\n        <div class=\"step-subtitle\" data-kid=\"65\">Шаг 04 // Инъекция технологий</div>\n        <h1 class=\"step-title\" id=\"title-4\" data-kid=\"66\">Стек и опции</h1>\n      </div>\n      \n      <div class=\"arch-input-group\" data-kid=\"67\">\n        <label class=\"arch-label\" data-kid=\"68\">Предпочтительный стек</label>\n        <div class=\"arch-chips\" id=\"tech-chips\" data-kid=\"69\">\n          \n        </div>\n      </div>\n\n      <div class=\"arch-input-group\" style=\"display: flex; gap: 40px; margin-top: 40px;\" data-kid=\"70\">\n        <label style=\"display: flex; align-items: center; gap: 12px; cursor: pointer;\" data-kid=\"71\">\n          <input type=\"checkbox\" id=\"design-needed\" style=\"width: 18px; height: 18px; accent-color: var(--arch-cyan);\" data-kid=\"72\">\n          <span class=\"arch-label\" style=\"margin-bottom:0\" data-kid=\"73\">Нужен дизайн (UI/UX)</span>\n        </label>\n        <label style=\"display: flex; align-items: center; gap: 12px; cursor: pointer;\" data-kid=\"74\">\n          <input type=\"checkbox\" id=\"urgent-deadline\" style=\"width: 18px; height: 18px; accent-color: var(--arch-cyan);\" data-kid=\"75\">\n          <span class=\"arch-label\" style=\"margin-bottom:0\" data-kid=\"76\">Срочный проект</span>\n        </label>\n      </div>\n    </div>\n\n    \n    <div id=\"step-5\" class=\"step-container hidden\" data-kid=\"77\">\n      <div class=\"step-header\" data-kid=\"78\">\n        <div class=\"step-subtitle\" data-kid=\"79\">Шаг 05 // Финальный отчет</div>\n        <h1 class=\"step-title\" id=\"title-5\" data-kid=\"80\">Протокол оценки</h1>\n      </div>\n      \n      <div style=\"background: rgba(255, 255, 255, 0.02); border: 1px solid var(--arch-border); padding: 40px;\" data-kid=\"81\">\n        <div style=\"display: grid; grid-template-columns: 1fr 1fr; gap: 40px; margin-bottom: 40px;\" data-kid=\"82\">\n          <div data-kid=\"83\">\n            <label class=\"arch-label\" data-kid=\"84\">Приблизительный бюджет</label>\n            <div id=\"result-price\" class=\"price-highlight\" data-kid=\"85\">0 — 0 ₽</div>\n          </div>\n          <div data-kid=\"86\">\n            <label class=\"arch-label\" data-kid=\"87\">Сроки реализации</label>\n            <div id=\"result-days\" class=\"price-highlight\" style=\"color: #fff;\" data-kid=\"88\">0 — 0 дней</div>\n          </div>\n        </div>\n\n        <label class=\"arch-label\" data-kid=\"89\">Распределение этапов (Gantt Mini)</label>\n        <div class=\"arch-timeline\" id=\"breakdown-timeline\" data-kid=\"90\">\n          \n        </div>\n\n        <div style=\"margin-top: 40px;\" data-kid=\"91\">\n          <label class=\"arch-label\" data-kid=\"92\">Инженерные рекомендации</label>\n          <ul id=\"recommendations-list\" style=\"margin: 0; padding-left: 20px; color: var(--arch-slate); font-size: 13px; line-height: 1.6;\" data-kid=\"93\">\n            \n          </ul>\n        </div>\n      </div>\n    </div>\n\n    \n    <div class=\"arch-btn-group\" data-kid=\"94\">\n      <button class=\"arch-btn hidden\" id=\"prev-btn\" data-kid=\"95\">Назад</button>\n      <button class=\"arch-btn arch-btn-primary\" id=\"next-btn\" data-kid=\"96\">Далее</button>\n    </div>\n  </main>\n</div>\n\n<script data-kid=\"97\">\n  // --- Data from page.tsx ---\n  const PROJECT_TYPES = [\n    { value: 'landing', label: 'Лендинг', icon: '🌐' },\n    { value: 'corporate', label: 'Корпоративный', icon: '🏢' },\n    { value: 'ecommerce', label: 'E-Commerce', icon: '🛒' },\n    { value: 'webapp', label: 'SaaS App', icon: '💻' },\n    { value: 'mobile', label: 'Мобильное', icon: '📱' },\n    { value: 'telegram', label: 'TG Бот', icon: '🤖' },\n    { value: 'crm', label: 'CRM/Admin', icon: '📊' },\n    { value: 'api', label: 'API/Backend', icon: '⚙️' },\n    { value: 'custom', label: 'Другое', icon: '✨' },\n  ];\n\n  const COMPLEXITY_MAP = {\n    landing: [\n      { value: 'simple', label: 'Простой', desc: '1 секция, без форм', mult: 1 },\n      { value: 'medium', label: 'Средний', desc: '3-5 секций, форма заявки', mult: 1.8 },\n      { value: 'complex', label: 'Продвинутый', desc: 'Анимации, калькулятор', mult: 3.5 },\n    ],\n    corporate: [\n      { value: 'simple', label: 'Базовый', desc: '5-7 страниц, каталог', mult: 1.5 },\n      { value: 'medium', label: 'Стандарт', desc: '15 страниц, блог', mult: 2.5 },\n      { value: 'complex', label: 'Расширенный', desc: 'ЛК, интеграции', mult: 4 },\n    ],\n    ecommerce: [\n      { value: 'simple', label: 'Мини-магазин', desc: '100 товаров, корзина', mult: 2 },\n      { value: 'medium', label: 'Стандарт', desc: 'Фильтры, оплата', mult: 3.5 },\n      { value: 'complex', label: 'Маркетплейс', desc: 'Мультивендор, ЛК', mult: 8 },\n    ],\n    webapp: [\n      { value: 'simple', label: 'MVP', desc: '1-2 функции', mult: 4 },\n      { value: 'medium', label: 'Стандарт', desc: 'Роли, 10 функций', mult: 7 },\n      { value: 'complex', label: 'Платформа', desc: 'Модули, API', mult: 15 },\n      { value: 'enterprise', label: 'Enterprise', desc: 'Микросервисы', mult: 25 },\n    ],\n    mobile: [\n      { value: 'simple', label: 'Простое', desc: '1-3 экрана', mult: 4.5 },\n      { value: 'medium', label: 'Стандарт', desc: '5-10 экранов, API', mult: 8 },\n      { value: 'complex', label: 'Сложное', desc: 'Оффлайн, платежи', mult: 14 },\n    ],\n    telegram: [\n      { value: 'simple', label: 'Простой', desc: 'Команды, 2 функции', mult: 0.8 },\n      { value: 'medium', label: 'Стандарт', desc: 'БД, оплата', mult: 1.5 },\n      { value: 'complex', label: 'Платформа', desc: 'Веб-апп, интеграции', mult: 3 },\n    ],\n    crm: [\n      { value: 'simple', label: 'Базовая', desc: 'CRUD, 3 сущности', mult: 3 },\n      { value: 'medium', label: 'Стандарт', desc: 'Роли, отчёты', mult: 5 },\n      { value: 'complex', label: 'Расширенная', desc: 'Автоматизации', mult: 10 },\n    ],\n    api: [\n      { value: 'simple', label: 'Простой', desc: '10 эндпоинтов', mult: 1.5 },\n      { value: 'medium', label: 'Стандарт', desc: 'Авторизация, доки', mult: 3 },\n      { value: 'complex', label: 'Микросервис', desc: 'Очереди, кэш', mult: 6 },\n    ],\n    custom: [\n      { value: 'simple', label: 'Простой', desc: 'Базовый функционал', mult: 1 },\n      { value: 'medium', label: 'Средний', desc: 'Несколько модулей', mult: 3 },\n      { value: 'complex', label: 'Сложный', desc: 'Много интеграций', mult: 10 },\n    ]\n  };\n\n  const FEATURES = [\n    'Авторизация / Личный кабинет', 'Оплата онлайн', 'Интеграция с CRM', \n    'Email/SMS уведомления', 'Админ-панель', 'Поиск и фильтры', \n    'Загрузка файлов', 'Мультиязычность', 'Аналитика / Графики', \n    'Push-уведомления', 'Экспорт в PDF/Excel', 'Гео-сервисы / Карты'\n  ];\n\n  const TECHS = [\n    'React / Next.js', 'Vue / Nuxt', 'Python / Django', \n    'Node.js', 'PHP / Laravel', 'Flutter / RN', 'WordPress'\n  ];\n\n  // --- State ---\n  let currentStep = 1;\n  const formData = {\n    projectType: 'landing',\n    complexity: 'simple',\n    description: '',\n    features: [],\n    customFeatures: [],\n    techStack: [],\n    designNeeded: false,\n    urgentDeadline: false\n  };\n\n  // --- Clock ---\n  function updateClock() {\n    const now = new Date();\n    document.getElementById('clock-display').textContent = now.toTimeString().split(' ')[0];\n  }\n  setInterval(updateClock, 1000);\n  updateClock();\n\n  // --- Rendering Functions ---\n  function renderStep() {\n    // Nav items\n    for(let i=1; i<=5; i++) {\n      const nav = document.getElementById(`nav-${i}`);\n      nav.classList.remove('active', 'completed');\n      if (i === currentStep) nav.classList.add('active');\n      else if (i < currentStep) nav.classList.add('completed');\n    }\n\n    // Containers\n    for(let i=1; i<=5; i++) {\n      document.getElementById(`step-${i}`).classList.add('hidden');\n    }\n    document.getElementById(`step-${currentStep}`).classList.remove('hidden');\n\n    // Title typing effect\n    const title = document.getElementById(`title-${currentStep}`);\n    const text = title.textContent;\n    title.innerHTML = `<span class=\"typing-effect\">${text}</span>`;\n\n    // Buttons\n    document.getElementById('prev-btn').classList.toggle('hidden', currentStep === 1 || currentStep === 5);\n    document.getElementById('next-btn').textContent = currentStep === 4 ? 'Рассчитать' : (currentStep === 5 ? 'Заказать проект' : 'Далее');\n  }\n\n  function initProjectTypes() {\n    const grid = document.getElementById('project-type-grid');\n    PROJECT_TYPES.forEach(type => {\n      const card = document.createElement('div');\n      card.className = `arch-card ${formData.projectType === type.value ? 'selected' : ''}`;\n      card.innerHTML = `\n        <div class=\"arch-card-icon\">${type.icon}</div>\n        <div class=\"arch-card-label\">${type.label}</div>\n      `;\n      card.onclick = () => {\n        formData.projectType = type.value;\n        document.querySelectorAll('#project-type-grid .arch-card').forEach(c => c.classList.remove('selected'));\n        card.classList.add('selected');\n        document.getElementById('custom-type-container').style.display = type.value === 'custom' ? 'block' : 'none';\n        initComplexity();\n      };\n      grid.appendChild(card);\n    });\n  }\n\n  function initComplexity() {\n    const list = document.getElementById('complexity-list');\n    list.innerHTML = '';\n    const options = COMPLEXITY_MAP[formData.projectType] || COMPLEXITY_MAP.custom;\n    \n    // Set default if current is not in list\n    if (!options.find(o => o.value === formData.complexity)) {\n      formData.complexity = options[0].value;\n    }\n\n    options.forEach(opt => {\n      const item = document.createElement('div');\n      item.className = `arch-card ${formData.complexity === opt.value ? 'selected' : ''}`;\n      item.style.flexDirection = 'row';\n      item.style.justifyContent = 'space-between';\n      item.style.marginBottom = '1px';\n      item.style.textAlign = 'left';\n      item.innerHTML = `\n        <div>\n          <div class=\"arch-card-label\">${opt.label}</div>\n          <div style=\"font-size: 11px; color: var(--arch-slate); margin-top: 5px;\">${opt.desc}</div>\n        </div>\n        <div class=\"font-mono\" style=\"font-size: 10px; color: var(--arch-cyan);\">x${opt.mult.toFixed(1)}</div>\n      `;\n      item.onclick = () => {\n        formData.complexity = opt.value;\n        document.querySelectorAll('#complexity-list .arch-card').forEach(c => c.classList.remove('selected'));\n        item.classList.add('selected');\n      };\n      list.appendChild(item);\n    });\n  }\n\n  function initFeatures() {\n    const container = document.getElementById('feature-chips');\n    container.innerHTML = '';\n    FEATURES.forEach(f => {\n      const chip = document.createElement('div');\n      chip.className = `arch-chip ${formData.features.includes(f) ? 'selected' : ''}`;\n      chip.textContent = f;\n      chip.onclick = () => {\n        if (formData.features.includes(f)) formData.features = formData.features.filter(item => item !== f);\n        else formData.features.push(f);\n        chip.classList.toggle('selected');\n      };\n      container.appendChild(chip);\n    });\n  }\n\n  function initTechs() {\n    const container = document.getElementById('tech-chips');\n    container.innerHTML = '';\n    TECHS.forEach(t => {\n      const chip = document.createElement('div');\n      chip.className = `arch-chip ${formData.techStack.includes(t) ? 'selected' : ''}`;\n      chip.textContent = t;\n      chip.onclick = () => {\n        if (formData.techStack.includes(t)) formData.techStack = formData.techStack.filter(item => item !== t);\n        else formData.techStack.push(t);\n        chip.classList.toggle('selected');\n      };\n      container.appendChild(chip);\n    });\n  }\n\n  // --- Calculation Logic ---\n  function calculate() {\n    const basePrice = 50000;\n    const baseDays = 7;\n    \n    const complexityOpt = (COMPLEXITY_MAP[formData.projectType] || COMPLEXITY_MAP.custom).find(o => o.value === formData.complexity);\n    const mult = complexityOpt ? complexityOpt.mult : 1;\n    \n    let price = basePrice * mult;\n    let days = baseDays * Math.sqrt(mult);\n    \n    // Addons\n    price += formData.features.length * 15000;\n    price += formData.customFeatures.length * 20000;\n    days += (formData.features.length + formData.customFeatures.length) * 1.5;\n    \n    if (formData.designNeeded) { price += basePrice * 0.4 * mult; days += 5; }\n    if (formData.urgentDeadline) { price *= 1.5; days *= 0.7; }\n    \n    const minPrice = Math.round(price * 0.9 / 1000) * 1000;\n    const maxPrice = Math.round(price * 1.2 / 1000) * 1000;\n    const minDays = Math.max(3, Math.floor(days * 0.8));\n    const maxDays = Math.ceil(days * 1.1);\n\n    document.getElementById('result-price').textContent = `${minPrice.toLocaleString('ru-RU')} — ${maxPrice.toLocaleString('ru-RU')} ₽`;\n    document.getElementById('result-days').textContent = `${minDays} — ${maxDays} дней`;\n\n    // Timeline breakdown\n    const timeline = document.getElementById('breakdown-timeline');\n    timeline.innerHTML = '';\n    const stages = [\n      { label: 'Аналитика и ТЗ', share: 0.15 },\n      { label: 'Проектирование UI/UX', share: formData.designNeeded ? 0.25 : 0.1 },\n      { label: 'Разработка Core', share: 0.4 },\n      { label: 'Интеграции и QA', share: 0.2 },\n    ];\n\n    stages.forEach(s => {\n      const div = document.createElement('div');\n      div.className = 'timeline-bar-container';\n      div.innerHTML = `\n        <div class=\"timeline-label\">${s.label}</div>\n        <div class=\"timeline-bar\" style=\"width: 0%; opacity: ${0.4 + s.share}\"></div>\n      `;\n      timeline.appendChild(div);\n      setTimeout(() => {\n        div.querySelector('.timeline-bar').style.width = `${s.share * 100}%`;\n      }, 100);\n    });\n\n    // Recommendations\n    const recs = document.getElementById('recommendations-list');\n    recs.innerHTML = '';\n    const items = [\n      `Рекомендуется использовать ${formData.techStack.length > 0 ? formData.techStack[0] : 'React/Next.js'} для обеспечения масштабируемости.`,\n      `Архитектура системы рассчитана на ${formData.complexity === 'complex' ? 'высокие нагрузки' : 'быстрый запуск MVP'}.`,\n      `Включено ${formData.features.length + formData.customFeatures.length} модулей в базовый план реализации.`\n    ];\n    items.forEach(text => {\n      const li = document.createElement('li');\n      li.textContent = text;\n      recs.appendChild(li);\n    });\n  }\n\n  // --- Events ---\n  document.getElementById('next-btn').onclick = () => {\n    if (currentStep < 5) {\n      if (currentStep === 4) calculate();\n      currentStep++;\n      renderStep();\n    } else {\n      alert('Протокол отправлен на сервер. Ожидайте подтверждения.');\n    }\n  };\n\n  document.getElementById('prev-btn').onclick = () => {\n    if (currentStep > 1) {\n      currentStep--;\n      renderStep();\n    }\n  };\n\n  document.getElementById('add-feature-btn').onclick = () => {\n    const input = document.getElementById('custom-feature-input');\n    const val = input.value.trim();\n    if (val && formData.customFeatures.length < 10) {\n      formData.customFeatures.push(val);\n      input.value = '';\n      renderCustomFeatures();\n    }\n  };\n\n  function renderCustomFeatures() {\n    const container = document.getElementById('custom-feature-chips');\n    container.innerHTML = '';\n    formData.customFeatures.forEach((f, i) => {\n      const chip = document.createElement('div');\n      chip.className = 'arch-chip selected';\n      chip.innerHTML = `${f} <span style=\"margin-left:8px; opacity:0.5;\">×</span>`;\n      chip.onclick = () => {\n        formData.customFeatures.splice(i, 1);\n        renderCustomFeatures();\n      };\n      container.appendChild(chip);\n    });\n  }\n\n  // Init\n  initProjectTypes();\n  initComplexity();\n  initFeatures();\n  initTechs();\n  renderStep();\n</script>",
